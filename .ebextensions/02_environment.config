option_settings:
  aws:elasticbeanstalk:application:environment:
    # AI Provider Configuration
    VITE_AI_PROVIDER: "gemini"
    
    # Note: Set sensitive environment variables through AWS Console
    # or EB CLI, not in this file:
    # - VITE_GEMINI_API_KEY
    # - AWS_ACCESS_KEY_ID (for Bedrock)
    # - AWS_SECRET_ACCESS_KEY (for Bedrock)
    
    # AWS Configuration
    AWS_REGION: "us-east-1"
    
    # Application Configuration
    APP_VERSION: "1.0.0"
    STATIC_DIR: "dist"
    HEALTH_CHECK_PATH: "/health"
    ENABLE_COMPRESSION: "true"
    
    # Retry Configuration
    VITE_MAX_RETRIES: "3"
    VITE_INITIAL_DELAY_MS: "1000"
    VITE_MAX_DELAY_MS: "10000"
    VITE_BACKOFF_MULTIPLIER: "2"
    
    # Rate Limiting
    VITE_MAX_REQUESTS_PER_MINUTE: "60"
    VITE_MAX_TOKENS_PER_MINUTE: "100000"
