# AI Provider Configuration
# Choose between 'gemini' (free tier, external service) or 'bedrock' (AWS-native, paid)
VITE_AI_PROVIDER=gemini

# Gemini Configuration (required if VITE_AI_PROVIDER=gemini)
# Get your API key from: https://makersuite.google.com/app/apikey
# Note: Server uses GEMINI_API_KEY (without VITE_ prefix)
GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# AWS Bedrock Configuration (required if VITE_AI_PROVIDER=bedrock)
# AWS region where Bedrock is available
AWS_REGION=us-east-1

# Bedrock model ID (default: Claude 3.5 Sonnet)
VITE_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# AWS Credentials (required if VITE_AI_PROVIDER=bedrock)
# These should be set in Elastic Beanstalk environment configuration
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# Server Configuration
PORT=8080
NODE_ENV=production
APP_VERSION=1.0.0

# Retry Configuration
VITE_MAX_RETRIES=3
VITE_INITIAL_DELAY_MS=1000
VITE_MAX_DELAY_MS=10000
VITE_BACKOFF_MULTIPLIER=2

# Rate Limiting Configuration
VITE_MAX_REQUESTS_PER_MINUTE=60
VITE_MAX_TOKENS_PER_MINUTE=100000

# Cost Implications:
# - Gemini: Free tier available (60 requests per minute)
# - Bedrock Claude 3.5 Sonnet: $3.00 per million input tokens, $15.00 per million output tokens
#
# Trade-offs:
# - Gemini: Better for development and testing, free tier, external service
# - Bedrock: AWS-native integration, better for production, no free tier, higher cost
