{
  "name": "productivity-copilot",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && tsc --project tsconfig.server.json",
    "start": "node dist-server/index.js",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:unit": "vitest run --dir tests/unit",
    "test:property": "vitest run --dir tests/property",
    "test:integration": "vitest run --dir tests/integration",
    "test:e2e": "playwright test",
    "analyze-bundle": "node scripts/analyze-bundle.js",
    "validate-build": "bash scripts/validate-build.sh",
    "deploy": "bash scripts/deploy.sh",
    "server": "node server/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.450.0",
    "@google/generative-ai": "^0.24.1",
    "compression": "^1.7.4",
    "express": "^4.18.2",
    "framer-motion": "^10.16.0",
    "helmet": "^7.1.0",
    "lucide-react": "^0.577.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.0",
    "react-router-dom": "^6.20.0",
    "web-vitals": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/ui": "^1.0.0",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "fast-check": "^3.15.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.1.0",
    "rollup-plugin-visualizer": "^5.11.0",
    "terser": "^5.46.0",
    "typescript": "^5.0.2",
    "vite": "^5.0.0",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^1.0.0"
  }
}
